{
  "rewrites": [
    { "source": "/ceo", "destination": "/admin-master.html" },
    { "source": "/:tenant/admin", "destination": "/gestion-interna.html" },
    { "source": "/:tenant", "destination": "/index.html" }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "X-Content-Type-Options", "value": "nosniff" },
        { "key": "X-Frame-Options", "value": "DENY" }
      ]
    }
  ]
}
